agent(name="Full-Stack Coding Agent" version=2.0.0 capabilities(file_system(read=true write=true delete=true watch=true permissions(owner=[read,write,delete] group=[read,write] other=[read])) terminal(execute=true background=true timeout_ms=30000 env_inherit=true sandbox(enabled=true max_memory_mb=512 max_cpu_percent=50 network_access=false filesystem_access=workspace-only)) git(read=true write=true remote_access=false branch_protection(require_review=true require_tests=true auto_merge=false)) ai(models(primary=gpt-4o fallback=claude-3.5-sonnet embedding=text-embedding-3-small) limits(max_tokens_per_request=4096 max_requests_per_minute=60 max_context_window=128000 cost_budget_daily_usd=50.00))) tools[name category parameters](
read_file filesystem (type=object properties(path(type=string description="File path") encoding(type=string enum=[utf-8,base64] default=utf-8) offset(type=integer minimum=0 default=0) limit(type=integer minimum=1 maximum=10000 default=1000)) required=path)
write_file filesystem (type=object properties(path=string content=string mode(type=string enum=[overwrite,append] default=overwrite) create_dirs(boolean default=true)) required=path,content)
search_files filesystem (type=object properties(pattern=string root(string default=.) max_results(integer default=100)) required=pattern)
grep search (type=object properties(query=string path=string include=string case_insensitive(boolean default=false)) required=query)
run_command terminal (type=object properties(command=string cwd=string timeout_ms(integer default=30000) capture(boolean default=true)) required=command)
git vcs (type=object properties(action(type=string enum=[status,diff,commit,push,pull,log]) message=string files(array items=string)) required=action)
create_component codegen (type=object properties(name=string path=string style(type=string enum=[tailwind,css,scss] default=tailwind) typescript(boolean default=true) test(boolean default=true)) required=name,path)
create_api_route codegen (type=object properties(path=string method(type=string enum=[GET,POST,PUT,DELETE]) auth(boolean default=true) validation(boolean default=true) rate_limit(integer default=100)) required=path,method)
database data (type=object properties(query=string params(array items=string) limit(integer default=100)) required=query)
deploy devops (type=object properties(service=string env(type=string enum=[staging,production]) replicas(integer default=2) memory_mb(integer default=512) rollback(boolean default=true)) required=service,env)
monitor devops (type=object properties(name=string metric=string condition(type=string enum=[gt,lt,eq]) threshold=number notify(array items=string)) required=name,metric,condition,threshold)
test testing (type=object properties(pattern(string default="**/*.test.ts") coverage(boolean default=false) watch(boolean default=false) parallel(boolean default=true)))
lint quality (type=object properties(fix(boolean default=false) paths(array items=string)))
typecheck quality (type=object properties(strict(boolean default=true) project(string default=tsconfig.json)))
build build (type=object properties(target(type=string enum=[development,production] default=production) minify(boolean default=true) sourcemap(boolean default=false)))
api_request network (type=object properties(url=string method(type=string enum=[GET,POST,PUT,DELETE] default=GET) headers(object additionalProperties=string) body=object timeout_ms(integer default=10000)) required=url)
web_search search (type=object properties(query=string num_results(integer default=5) safe_search(boolean default=true)) required=query)
generate_image media (type=object properties(prompt=string size(type=string enum=[256x256,512x512,1024x1024] default=512x512) style(type=string enum=[natural,vivid] default=natural)) required=prompt)
email notification (type=object properties(to=string subject=string body=string html(boolean default=false) priority(type=string enum=[low,normal,high] default=normal)) required=to,subject,body)
slack notification (type=object properties(channel=string message=string thread_ts=string blocks(array items=object)) required=channel,message)
)
