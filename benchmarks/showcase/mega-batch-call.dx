tool_calls[name arguments](
read_file(path=src/index.ts encoding=utf-8 offset=0 limit=100)
grep(query="export default" path=src/ include="*.ts" case_insensitive=false)
search_files(pattern="**/*.test.ts" root=src/ max_results=50)
run_command(command="npm run build" cwd=. timeout_ms=60000 capture=true)
git(action=diff files=[src/index.ts,src/utils.ts])
create_component(name=UserCard path=src/components/ style=tailwind typescript=true test=true)
create_api_route(path=/api/users method=GET auth=true validation=true rate_limit=100)
database(query="SELECT * FROM users WHERE active = $1" params=[true] limit=50)
deploy(service=api-gateway env=staging replicas=2 memory_mb=1024 rollback=true)
monitor(name="High Latency" metric=request_latency_p99 condition=gt threshold=500 notify=[slack,pagerduty])
test(pattern="**/*.test.ts" coverage=true watch=false parallel=true)
lint(fix=true paths=[src/])
typecheck(strict=true project=tsconfig.json)
build(target=production minify=true sourcemap=false)
api_request(url="https://api.example.com/health" method=GET timeout_ms=5000)
web_search(query="DX Serializer token efficiency" num_results=5 safe_search=true)
email(to=team@company.com subject="Deploy Complete" body="Staging deploy successful" html=false priority=normal)
slack(channel="#deployments" message="Deployed api-gateway to staging" blocks=[])
)
