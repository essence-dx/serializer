tools[100]:
  - name: fs1
    description: fs tool 1
    category: fs
    parameters:
      type: object
      properties:
        input:
          type: string
          enum[4]: ts,js,rs,go
          default: ts
          description: Select fs mode
        output:
          type: string
          enum[4]: ts,js,rs,go
          default: js
          description: Output format
        format:
          type: string
          enum[4]: ts,js,rs,go
          default: rs
          description: Format option
        verbose:
          type: boolean
          default: true
          description: Enable verbose
        count:
          type: integer
          minimum: 1
          maximum: 100
          default: 10
          description: Max count
        dryRun:
          type: boolean
          default: false
          description: Dry run mode
      required[2]: input,output
