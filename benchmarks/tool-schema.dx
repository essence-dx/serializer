tools[name description parameters](get_weather "Get current weather and forecast for a location"(type=object properties(location(type=string description="City and country") unit(type=string enum=[celsius fahrenheit]) forecast_days(type=integer minimum=1 maximum=7)) required=[location]) search_web "Search the web with optional filters"(type=object properties(query(type=string description="Search query") max_results(type=integer default=10) language(type=string default=en) safe_search(type=boolean default=true) time_range(type=string enum=[day week month year])) required=[query]) create_file "Create or overwrite a file in the workspace"(type=object properties(path(type=string description="File path relative to workspace root") content(type=string description="File content") overwrite(type=boolean default=false) create_dirs(type=boolean default=true)) required=[path content]) run_code "Execute code in a sandboxed environment"(type=object properties(language(type=string enum=[javascript python rust]) code(type=string) timeout_ms(type=integer default=30000) env(type=object additionalProperties(type=string))) required=[language code]))