name=get_weather description="Get current weather and forecast for a location" parameters.type=object parameters.properties.location.type=string parameters.properties.location.description="City and country" parameters.properties.unit.type=string parameters.properties.unit.enum=[celsius,fahrenheit] parameters.properties.unit.default=celsius parameters.properties.forecast_days.type=integer parameters.properties.forecast_days.minimum=1 parameters.properties.forecast_days.maximum=7 parameters.properties.forecast_days.default=3 parameters.required=[location]
