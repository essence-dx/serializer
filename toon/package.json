{
  "name": "@toon-format/monorepo",
  "type": "module",
  "version": "2.3.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r --filter=./packages/** run build",
    "automd": "automd",
    "docs:dev": "vitepress dev docs",
