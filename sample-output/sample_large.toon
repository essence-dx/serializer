project: DX Serializer
version: 1.0.0
license: MIT
language: Rust
status: production
repository: "https://github.com/dx-www/dx-www"
docs: "https://docs.rs/dx-serializer"
keywords[8]: serialization,parser,performance,zero-copy,token-efficient,llm,rkyv,wasm
features[7]: converters,compression,serde-compat,wasm,tiktoken,parallel,watch
