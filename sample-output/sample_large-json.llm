project="DX Serializer"
version=1.0.0
license=MIT
language=Rust
status=production
repository=https://github.com/dx-www/dx-www
docs=https://docs.rs/dx-serializer
keywords=[serialization parser performance zero-copy token-efficient llm rkyv wasm]
features=[converters compression serde-compat wasm tiktoken parallel watch]
dependencies=[[name=serde,version=1.0.228,optional=true] [name=serde_json,version=1.0.150,optional=true] [name=serde_yaml,version=0.9.34,optional=true] [name=toml,version=0.8.23,optional=true] [name=rkyv,version=0.8.16,optional=false] [name=bincode,version=1.3.3,optional=true] [name=lz4_flex,version=0.11,optional=true] [name=zstd,version=0.13,optional=true] [name=rayon,version=1.12.0,optional=true] [name=memmap2,version=0.9,optional=true] [name=tiktoken-rs,version=0.6,optional=true] [name=tokenizers,version=0.21,optional=true] [name=notify,version=6.1,optional=true] [name=blake3,version=1.5,optional=false] [name=thiserror,version=2.0,optional=false] [name=indexmap,version=2.7,optional=false] [name=hashbrown,version=0.15,optional=false] [name=rustc-hash,version=1.1,optional=false] [name=bytes,version=1.5,optional=false] [name=memchr,version=2.7,optional=false] [name=bytemuck,version=1.18,optional=false]]
dev-dependencies=[[name=criterion,version=0.5,optional=false] [name=proptest,version=1.11,optional=false] [name=tempfile,version=3.27,optional=false] [name=postcard,version=1.0,optional=false] [name=hex,version=0.4,optional=false]]
team=[[name="Alice Chen",role=Architect,location=SF,years=12] [name="Bob Smith",role=Engineer,location=NYC,years=8] [name="Carol Davis",role=Engineer,location=London,years=6] [name="Diana Lee",role=Designer,location=SF,years=5] [name="Evan Wu",role=Engineer,location=Tokyo,years=4] [name="Fiona Brown",role=QA,location=London,years=3] [name="George Kim",role=Architect,location=SF,years=10] [name="Hannah Liu",role=Engineer,location=NYC,years=7] [name="Ian Patel",role=Designer,location=London,years=4] [name="Julia Torres",role=Engineer,location=SF,years=6]]