[project]
name                         = dx-os
version                      = 1.0.0
description                  = DX Operating System — resource monitor, serializer, and ecosystem CLI
license                      = Apache-2.0
repository                   = https://github.com/essence-dx/os

[build]
compiler                     = gcc
std                          = c++23
opt                          = -O2
static                       = true

[scripts]
settings                     = 
recipes:
- 
- 
- 
- 
