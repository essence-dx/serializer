[project]
name                         = dx-os
version                      = 1.0.0
description                  = DX Operating System
license                      = Apache-2.0
repository                   = https://github.com/essence-dx/os

[build]
compiler                     = gcc
std                          = c++23
opt                          = -O2
static                       = true

[recipes:1]
name                         = build
group                        = all
doc                          = Build all workspace crates
script                       = cargo build --workspace

[recipes:2]
name                         = build-release
group                        = all
doc                          = Build all crates in release mode
script                       = cargo build --workspace --release

[recipes:3]
name                         = check
group                        = all
doc                          = Run cargo check on the whole workspace
script                       = cargo check --workspace

[recipes:4]
name                         = build-cli
group                        = cli
doc                          = Build dx-cli
script                       = cargo build --manifest-path cli/Cargo.toml

[recipes:5]
name                         = build-serializer
group                        = serializer
doc                          = Build dx-serializer
script                       = cargo build --manifest-path serializer/Cargo.toml

[recipes:6]
name                         = build-script
group                        = script
doc                          = Build dx-script
script                       = cargo build --manifest-path script/Cargo.toml

[recipes:7]
name                         = build-forge
group                        = forge
doc                          = Build dx-forge
script                       = cargo build --manifest-path forge/Cargo.toml

[recipes:8]
name                         = build-style
group                        = style
doc                          = Build dx-style
script                       = cargo build --manifest-path style/Cargo.toml

[recipes:9]
name                         = build-check
group                        = check
doc                          = Build dx-check
script                       = cargo build --manifest-path check/Cargo.toml

[recipes:10]
name                         = build-js
group                        = js
doc                          = Build dx-js
script                       = bun run build --cwd js

[recipes:11]
name                         = build-py
group                        = py
doc                          = Build dx-py
script                       = cd py && cargo build

[recipes:12]
name                         = test
group                        = all
doc                          = Run all workspace tests
script                       = cargo test --workspace

[recipes:13]
name                         = test-cli
group                        = cli
doc                          = Test dx-cli
script                       = cargo test --manifest-path cli/Cargo.toml

[recipes:14]
name                         = test-serializer
group                        = serializer
doc                          = Test dx-serializer
script                       = cargo test --manifest-path serializer/Cargo.toml

[recipes:15]
name                         = test-script
group                        = script
doc                          = Test dx-script
script                       = cargo test --manifest-path script/Cargo.toml

[recipes:16]
name                         = lint
group                        = all
doc                          = Run clippy on workspace
script                       = cargo clippy --workspace -- -D warnings

[recipes:17]
name                         = fmt
group                        = all
doc                          = Check formatting
script                       = cargo fmt --check

[recipes:18]
name                         = audit
group                        = all
doc                          = Run cargo audit
script                       = cargo audit

[recipes:19]
name                         = dev-www
group                        = www
doc                          = Start DX-WWW dev server
script                       = dx dev

[recipes:20]
name                         = dev-website
group                        = website
doc                          = Start DX website dev server
script                       = dx site dev

[recipes:21]
name                         = style-analyze
group                        = style
doc                          = Analyze styles
script                       = dx style analyze .

[recipes:22]
name                         = style-check
group                        = style
doc                          = Check styles
script                       = dx style check

[recipes:23]
name                         = serialize
group                        = serializer
doc                          = Serialize dx config to LLM format
script                       = dx-serializer human dx

[recipes:24]
name                         = serialize-dir
group                        = serializer
doc                          = Serialize all files in dir
script                       = dx-serializer human . --dir

[recipes:25]
name                         = forge-status
group                        = forge
doc                          = Show forge package status
script                       = dx forge status

[recipes:26]
name                         = forge-list
group                        = forge
doc                          = List forge packages
script                       = dx forge package list --json

[aliases:1]
name                         = b
target                       = build

[aliases:2]
name                         = br
target                       = build-release

[aliases:3]
name                         = c
target                       = check

[aliases:4]
name                         = t
target                       = test

[aliases:5]
name                         = l
target                       = lint

[aliases:6]
name                         = f
target                       = fmt

[aliases:7]
name                         = a
target                       = audit

[aliases:8]
name                         = bc
target                       = build-cli

[aliases:9]
name                         = bs
target                       = build-serializer

[aliases:10]
name                         = bx
target                       = build-script

[aliases:11]
name                         = tc
target                       = test-cli

[aliases:12]
name                         = ts
target                       = test-serializer

[aliases:13]
name                         = tx
target                       = test-script

[aliases:14]
name                         = dw
target                       = dev-www

[aliases:15]
name                         = ds
target                       = dev-website

[aliases:16]
name                         = sa
target                       = style-analyze

[aliases:17]
name                         = sr
target                       = serialize

[aliases:18]
name                         = fg
target                       = forge-status

[vars:1]
name                         = DX ROOT
value                        = none
export                       = false

[vars:2]
name                         = CARGO PROFILE
value                        = debug
export                       = false

[vars:3]
name                         = RUST LOG
value                        = info
export                       = false

[vars:4]
name                         = DX SERIALIZER OPT
value                        = human
export                       = false

[scripts]

[settings]
shell                        = bash
fallback                     = true
shell                        = bash
fallback                     = true

[settings]
shell                        = bash
fallback                     = true

[matrix:1]
os                           = linux
arch                         = x86 64

[matrix:2]
os                           = linux
arch                         = aarch64

[matrix:3]
os                           = macos
arch                         = x86 64

[matrix:4]
os                           = macos
arch                         = aarch64

[matrix:5]
os                           = windows
arch                         = x86 64

[steps:1]
name                         = checkout
script                       = actions/checkout@v4

[steps:2]
name                         = setup
script                       = actions/setup-node@v4

[steps:3]
name                         = build
script                       = cargo build --workspace

[steps:4]
name                         = test
script                       = cargo test --workspace

[steps:5]
name                         = lint
script                       = cargo clippy --workspace -- -D warnings

[steps:6]
name                         = fmt-check
script                       = cargo fmt --check

[ci]
runner                       = ubuntu-latest
timeout                      = 30
parallel                     = true

[dependencies:1]
name                         = serde
version                      = 1
optional                     = false

[dependencies:2]
name                         = tokio
version                      = 1.35
optional                     = false

[dependencies:3]
name                         = clap
version                      = 4.5
optional                     = false

[dependencies:4]
name                         = rayon
version                      = 1.9
optional                     = true

[dependencies:5]
name                         = tracing
version                      = 0.1
optional                     = false

[dependencies:6]
name                         = reqwest
version                      = 0.12
optional                     = true

[dependencies:7]
name                         = serde json
version                      = 1
optional                     = false

[dependencies:8]
name                         = thiserror
version                      = 1
optional                     = false

[dependencies:9]
name                         = anyhow
version                      = 1
optional                     = false

[features]
default:
- serde
- tokio
- clap
- tracing
- serde json
- thiserror
- anyhow
gpu                          = true
wasm                         = false
dbg                          = false