name                         = dx-os
version                      = 1.0.0
description                  = DX Operating System
license                      = Apache-2.0
repository                   = https://github.com/essence-dx/os
compiler                     = gcc
std                          = c++23
opt                          = -O2
static                       = true
shell                        = bash
fallback                     = true
runner                       = ubuntu-latest
timeout                      = 30
parallel                     = true
