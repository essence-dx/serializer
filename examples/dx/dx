project(
  name    = dx-os
  version = 1.0.0
)

build(
  command = cargo build
  target  = wasm32-unknown-unknown
)

scripts(
  dev   = cargo watch
  build = cargo build --release
  test  = cargo test
  lint  = cargo clippy
)

ci(
  provider = github-actions
  runner   = ubuntu-latest
  toolchain = stable
)

features(
  wasm       = enabled
  io_uring   = planned
  zero_copy  = enabled
)

aliases[name target](
  build  release
  test   debug
  docs   documentation
  lint   check
  bench  benchmark
)

deps[name version](
  serde   1.0
  tokio   1.35
  clap    4.5
  reqwest 0.12
  hyper   1.3
  axum    0.7
  sqlx    0.8
  diesel  2.2
)

tags(
  language = rust
  category = serialization
  format   = dx
)

authors(
  lead  = dx-team
  role  = maintainer
)

stats(
  stars    = 2500
  forks    = 120
  issues   = 15
  prs      = 8
)
