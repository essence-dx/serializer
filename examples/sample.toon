name: dx-os
version: 1.0.0
description: Token-efficient serialization for LLM context windows
author: DX Team
license: MIT OR Apache-2.0
language: Rust
rust_version: "1.85"
edition: "2024"
repository: "https://github.com/dx-www/dx-os"
keywords[5]: serialization,parser,format,performance,zero-copy
categories[3]: encoding,parser-implementations,asynchronous
features:
  default[3]: converters,compression,serde-compat
  converters[4]: serde,serde_json,serde_yaml,toml
  compression[2]: compression-lz4,compression-zstd
  "token-counting"[2]: tiktoken,tokenizers-hf
  full[6]: converters,compression,watch,token-counting,derive,parallel
dependencies:
  blake3: "1.5"
  bytes: "1.5"
  bytemuck: "1.18"
  indexmap: "2.7"
  memchr: "2.7"
  rkyv: "0.8"
stats:
  stars: 2500
  forks: 120
  issues: 15
  open_prs: 8
  contributors: 12